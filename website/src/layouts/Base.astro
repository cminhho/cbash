---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "CBASH CLI — Command. Compose. Control.",
  description = "Shell productivity toolkit for developers — 200+ aliases, 15+ plugins, zero configuration. Works on Bash 4+/Zsh, macOS · Linux · WSL. Free & open source (MIT).",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const favicon32 = `${base}/assets/favicon-32x32.png`;
const favicon16 = `${base}/assets/favicon-16x16.png`;
const ogImage = new URL(`${base}/assets/cbash-logo.png`, Astro.site).href;
const canonical = new URL(base + "/", Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="cbash, cli, bash, zsh, shell, productivity, developer tools, git, docker, kubernetes, aws" />
    <meta name="author" content="cminhho" />
    <meta name="theme-color" content="#0a0a0f" />
    <link rel="icon" type="image/png" sizes="32x32" href={favicon32} />
    <link rel="icon" type="image/png" sizes="16x16" href={favicon16} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Set theme before paint to avoid flash (dark default) -->
    <script is:inline>
      try {
        if (localStorage.getItem("cbash-theme") === "light") document.documentElement.classList.add("light");
      } catch (e) {}
    </script>
  </head>
  <body>
    <slot />

    <!-- Scroll reveal (no animation library) -->
    <script is:inline>
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) { e.target.classList.add("is-visible"); io.unobserve(e.target); }
          }
        },
        { rootMargin: "0px 0px -10% 0px", threshold: 0.05 }
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
    </script>
  </body>
</html>
