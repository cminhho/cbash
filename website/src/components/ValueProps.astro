---
import { Icon } from "astro-icon/components";
const items = [
  { icon: "lucide:zap", title: "Type less", body: "Replace complex loops and scripts with single commands. What took 10 lines now takes one." },
  { icon: "lucide:blocks", title: "Composable", body: "A plugin architecture you extend in minutes — drop your own into plugins/<name>/." },
  { icon: "lucide:terminal", title: "Shell-native", body: "No runtime, no daemon, no config. Source it and go on Bash 4+ and Zsh." },
];
---
<section id="features" class="border-t border-border/60 py-20 sm:py-28">
  <div class="mx-auto max-w-content px-4 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <span class="section-label">Why cbash</span>
      <h2 class="font-mono text-2xl font-bold tracking-tight sm:text-3xl">Built for developer productivity</h2>
      <p class="mt-3 text-muted-foreground">Replace repetitive shell commands with simple, composable tools that work out of the box.</p>
    </div>
    <div class="mt-12 grid gap-4 sm:grid-cols-3">
      {items.map((p) => (
        <div class="reveal card-surface rounded-md p-6 transition-colors hover-green">
          <span class="icon-chip h-11 w-11"><Icon name={p.icon} class="h-5 w-5" /></span>
          <h3 class="mt-4 font-semibold">{p.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
