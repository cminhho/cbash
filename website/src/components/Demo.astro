---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<section class="border-t border-border/60 py-20 sm:py-28">
  <div class="mx-auto max-w-content px-4 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <span class="section-label">Demo</span>
      <h2 class="font-mono text-2xl font-bold tracking-tight sm:text-3xl">Watch it work</h2>
      <p class="mt-3 text-muted-foreground">Real terminal, real commands — no edits.</p>
    </div>

    <div class="reveal mx-auto mt-10 max-w-3xl">
      <div class="terminal overflow-hidden rounded-md" style="box-shadow: var(--shadow);">
        <div class="t-head">
          <span class="t-dot bg-[#ff5f57]"></span><span class="t-dot bg-[#febc2e]"></span><span class="t-dot bg-[#28c840]"></span>
          <span class="t-title">cbash — demo</span>
        </div>
        <img src={`${base}/assets/demo.gif`} alt="cbash CLI demo: running commands in the terminal" loading="lazy" decoding="async" class="block w-full" />
      </div>
    </div>
  </div>
</section>
