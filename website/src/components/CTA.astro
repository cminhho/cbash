---
import { Icon } from "astro-icon/components";
import { GITHUB } from "../consts";
---
<section class="border-t border-border/60 py-20 sm:py-28">
  <div class="mx-auto max-w-content px-4 sm:px-6 lg:px-8">
    <div class="reveal relative overflow-hidden rounded-lg border border-[color:var(--border)] card-surface px-6 py-14 text-center sm:px-12">
      <div class="pointer-events-none absolute inset-0 -z-10 opacity-50" style="background: radial-gradient(ellipse at 50% 0%, rgba(0,255,136,0.18), transparent 60%);" aria-hidden="true"></div>
      <h2 class="mx-auto max-w-xl font-mono text-2xl font-bold tracking-tight sm:text-3xl">Ready to ship faster?</h2>
      <p class="mx-auto mt-3 max-w-lg text-muted-foreground">Compose your terminal workflow into short, memorable commands. Free &amp; open source (MIT).</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="#install" class="btn btn-primary"><Icon name="lucide:terminal" class="h-4 w-4" /> Install cbash</a>
        <a href={GITHUB} target="_blank" rel="noopener" class="btn btn-secondary"><Icon name="lucide:github" class="h-4 w-4" /> View source</a>
      </div>
    </div>
  </div>
</section>
