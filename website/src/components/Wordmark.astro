---
interface Props { class?: string }
const { class: className = "" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<span class={`inline-flex items-center gap-2.5 font-mono font-bold ${className}`}>
  <img src={`${base}/assets/cbash-logo.png`} alt="cbash logo" width="28" height="28" class="h-7 w-7 rounded-md" />
  <span><span class="ink">&gt;_</span> cbash</span>
</span>
