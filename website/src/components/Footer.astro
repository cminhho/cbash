---
import { Icon } from "astro-icon/components";
import Wordmark from "./Wordmark.astro";
import { GITHUB, NAV } from "../consts";
---
<footer class="border-t border-border/60 py-12">
  <div class="mx-auto max-w-content px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-start justify-between gap-8 sm:flex-row">
      <div class="max-w-xs">
        <Wordmark class="text-[15px]" />
        <p class="mt-3 text-sm text-muted-foreground">Command. Compose. Control. Shell productivity toolkit for modern developers.</p>
      </div>
      <div class="flex gap-12">
        <div>
          <h4 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Product</h4>
          <ul class="mt-3 space-y-2 text-sm">
            {NAV.map((n) => <li><a href={n.href} class="text-muted-foreground transition-colors hover:text-foreground">{n.name}</a></li>)}
          </ul>
        </div>
        <div>
          <h4 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Project</h4>
          <ul class="mt-3 space-y-2 text-sm">
            <li><a href={GITHUB} target="_blank" rel="noopener" class="text-muted-foreground transition-colors hover:text-foreground">GitHub</a></li>
            <li><a href={`${GITHUB}/blob/master/CONTRIBUTING.md`} target="_blank" rel="noopener" class="text-muted-foreground transition-colors hover:text-foreground">Contributing</a></li>
            <li><a href={`${GITHUB}/blob/master/LICENSE`} target="_blank" rel="noopener" class="text-muted-foreground transition-colors hover:text-foreground">MIT License</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="mt-10 flex flex-col items-center justify-between gap-3 border-t border-border/60 pt-6 sm:flex-row">
      <p class="font-mono text-xs text-muted-foreground">© 2026 CBASH CLI · MIT License</p>
      <div class="flex flex-wrap gap-4 font-mono text-xs text-muted-foreground">
        <span>Bash 4+ / Zsh</span><span>v1.2.0</span><span>macOS • Linux • WSL</span>
      </div>
    </div>
  </div>
</footer>
